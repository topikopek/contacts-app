<div class="container mt-4">
    <div class="col-md-6">
          <div class="row">
        <h4 class="mb-3 fw-bold">Tambah Contact</h4>
  <% if (typeof errors !== 'undefined') { %>
   <div class="alert alert-danger" role="alert">
    <ul>
      <% errors.forEach(error => { %>
       <li><%= error.msg %></li>
      <% }) %>
    </ul>
  </div>
  <% } %>
      <form method="post" action="/contact">
        <div class="mb-3">
          <label for="nama" class="form-label">Nama Lengkap</label>
          <input
            type="text"
            class="form-control"
            id="nama"
            name="nama"
            required
          />
        </div>
        <div class="mb-3">
          <label for="nohp" class="form-label">No.HP</label>
          <input
            type="text"
            class="form-control"
            id="nohp"
            name="nohp"
            required
          />
        </div>
        <div class="mb-3">
          <label for="email" class="form-label">Email</label>
          <input
            type="email"
            class="form-control"
            id="email"
            name="email"
            required
          />
        </div>
        <button type="submit" class="btn btn-primary">Tambah Contact</button>
      </form>
    </div>
  </div>
</div>
